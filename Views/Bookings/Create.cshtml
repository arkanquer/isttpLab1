@model HotelBookingSystem.Models.Booking

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Оформлення нового бронювання</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Клієнт</label>
                                <select asp-for="Clientid" class="form-select" asp-items="ViewBag.ClientIdList">
                                    <option value="">-- Оберіть клієнта --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Номер кімнати</label>
                                <select asp-for="Roomid" class="form-select" asp-items="ViewBag.RoomIdList">
                                    <option value="">-- Оберіть номер --</option>
                                </select>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label">Адміністратор (хто оформлює)</label>
                                <select asp-for="Employeeid" class="form-select" asp-items="ViewBag.EmployeeIdList">
                                    <option value="">-- Оберіть себе --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Дата заїзду</label>
                                <input asp-for="Checkindate" type="date" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Дата виїзду</label>
                                <input asp-for="Checkoutdate" type="date" class="form-control" required />
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between mt-3">
                            <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
                            <button type="submit" class="btn btn-dark">Підтвердити бронювання</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>