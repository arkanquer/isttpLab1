@using HotelBookingSystem.ViewModels
@model CreateBookingViewModel

@{
    ViewData["Title"] = "Оформлення бронювання";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 mx-auto" style="max-width: 700px;">
        <div class="card-body p-5">
            <h2 class="text-center fw-bold mb-4">Бронювання номера</h2>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <input type="hidden" asp-for="RoomId" />

                <div class="alert alert-light border border-dark text-center py-4 mb-4 shadow-sm rounded-3">
                    <span class="text-muted d-block small text-uppercase mb-1">Ви бронюєте номер:</span>
                    <h2 class="fw-bold mb-0 text-dark">№ @Model.RoomId</h2>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary small text-uppercase">Дата заїзду</label>
                        <input asp-for="CheckInDate" type="date" class="form-control border-dark shadow-sm" />
                        <span asp-validation-for="CheckInDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary small text-uppercase">Дата виїзду</label>
                        <input asp-for="CheckOutDate" type="date" class="form-control border-dark shadow-sm" />
                        <span asp-validation-for="CheckOutDate" class="text-danger small"></span>
                    </div>
                </div>

                <h5 class="fw-bold mb-3 text-uppercase small text-secondary">Додаткові послуги</h5>
                <div class="list-group mb-4 shadow-sm rounded-3 overflow-hidden border-dark">
                    @for (int i = 0; i < Model.AvailableServices.Count; i++)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <div class="form-check">
                                <input type="hidden" asp-for="AvailableServices[i].ServiceId" />
                                <input type="hidden" asp-for="AvailableServices[i].Name" />
                                <input type="hidden" asp-for="AvailableServices[i].Price" />
                                
                                <input asp-for="AvailableServices[i].IsSelected" class="form-check-input border-dark" />
                                <label class="form-check-label ms-2 fw-medium" for="AvailableServices_@(i)__IsSelected">
                                    @Model.AvailableServices[i].Name
                                    <span class="text-muted ms-1 small">(@Model.AvailableServices[i].Price.ToString("N2") грн)</span>
                                </label>
                            </div>
                            <div style="width: 80px;">
                                <input asp-for="AvailableServices[i].Quantity" type="number" min="1" 
                                       class="form-control form-control-sm border-dark text-center" />
                            </div>
                        </div>
                    }
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-dark btn-lg rounded-pill shadow-sm py-3 fw-bold">
                        Підтвердити замовлення
                    </button>
                    <a asp-controller="Rooms" asp-action="Index" class="btn btn-link text-muted text-decoration-none text-center small">
                        Скасувати та повернутися
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}