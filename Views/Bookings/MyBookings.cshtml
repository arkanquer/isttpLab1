@model IEnumerable<HotelBookingSystem.Models.Booking>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Мої бронювання</h2>
        <a asp-controller="Rooms" asp-action="Index" class="btn btn-outline-primary rounded-pill">
            <i class="bi bi-plus-lg"></i> Забронювати ще
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size: 4rem;"></i>
            <p class="fs-4 text-muted mt-3">У вас поки немає бронювань.</p>
            <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary btn-lg mt-2">Переглянути номери</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm border-0 rounded-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-0">@item.Room?.Roomtype</h5>
                                    <small class="text-muted">Номер: @item.Room?.Roomnumber</small>
                                </div>
                                <span class="badge rounded-pill @(item.Status == "Confirmed" ? "bg-success" : item.Status == "Pending" ? "bg-warning text-dark" : "bg-danger")">
                                    @item.Status
                                </span>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between small text-muted mb-1">
                                    <span>Заїзд:</span>
                                    <span class="fw-bold text-dark">@item.Checkindate?.ToString("dd.MM.yyyy")</span>
                                </div>
                                <div class="d-flex justify-content-between small text-muted">
                                    <span>Виїзд:</span>
                                    <span class="fw-bold text-dark">@item.Checkoutdate?.ToString("dd.MM.yyyy")</span>
                                </div>
                            </div>

                            <hr class="text-muted opacity-25">

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="text-muted small">Сума до сплати:</span>
                                <span class="fs-5 fw-bold text-primary">@item.Totalprice грн</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>