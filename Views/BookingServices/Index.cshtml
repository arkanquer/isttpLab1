@model HotelBookingSystem.Models.Booking

@{
    var checkIn = Model.Checkindate ?? DateTime.Now;
    var checkOut = Model.Checkoutdate ?? DateTime.Now.AddDays(1);
    var days = (int)(checkOut - checkIn).TotalDays;
    if (days < 1) days = 1;

    var roomPrice = Model.Roompriceatbooking ?? 0;
    var stayTotal = roomPrice * (decimal)days;
    
    var servicesTotal = Model.BookingServices.Sum(s => (s.Priceatbooking ?? 0) * (s.Quantity ?? 1));
}

<div class="container mt-4">
    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1 text-dark">Рахунок №@Model.Bookingid</h2>
                <p class="text-muted mb-0">
                    Клієнт: <strong>@(Model.Client?.Fullname ?? "Гість")</strong> | 
                    Номер: <strong>@(Model.Room?.Roomnumber ?? "—")</strong>
                </p>
            </div>
            <div class="text-end">
                <div class="small text-muted">Період проживання:</div>
                <div class="fw-bold">@checkIn.ToString("dd.MM.yyyy") — @checkOut.ToString("dd.MM.yyyy") (@days діб)</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white fw-bold">Додати послугу</div>
                <div class="card-body">
                    <form asp-action="AddService" method="post">
                        <input type="hidden" name="bookingId" value="@Model.Bookingid" />
                        <div class="mb-3">
                            <label class="form-label small">Оберіть послугу</label>
                            <select name="serviceId" class="form-select" asp-items="ViewBag.ServiceList">
                                <option value="">Виберіть із списку</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Кількість</label>
                            <input type="number" name="quantity" value="1" min="1" class="form-control shadow-sm" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 shadow-sm">➕ Додати</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0 bg-success text-white">
                <div class="card-body text-center">
                    <div class="small opacity-75">Загальна сума до оплати</div>
                    <h2 class="display-6 fw-bold mb-0">@((Model.Totalprice ?? stayTotal).ToString("N2")) грн</h2>
                    <div class="small mt-1 text-white-50">Проживання: @stayTotal.ToString("N2") грн</div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Опис</th>
                                <th class="text-center">Ціна</th>
                                <th class="text-center">К-ть</th>
                                <th class="text-end">Сума</th>
                                <th class="text-center"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="table-primary border-primary">
                                <td><strong>Проживання в готелі</strong></td>
                                <td class="text-center">@roomPrice.ToString("N2")</td>
                                <td class="text-center">@days</td>
                                <td class="text-end fw-bold">@stayTotal.ToString("N2")</td>
                                <td></td>
                            </tr>

                            @foreach (var item in Model.BookingServices)
                            {
                                var rowSum = (item.Priceatbooking ?? 0) * (item.Quantity ?? 1);
                                <tr>
                                    <td>@item.Service?.Name</td>
                                    <td class="text-center">@item.Priceatbooking?.ToString("N2")</td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm border rounded bg-white">
                                            <form asp-action="UpdateQuantity" method="post">
                                                <input type="hidden" name="bookingId" value="@item.Bookingid" />
                                                <input type="hidden" name="serviceId" value="@item.Serviceid" />
                                                <input type="hidden" name="delta" value="-1" />
                                                <button type="submit" class="btn btn-light" @(item.Quantity <= 1 ? "disabled" : "")>-</button>
                                            </form>
                                            <span class="px-2 align-self-center fw-bold">@item.Quantity</span>
                                            <form asp-action="UpdateQuantity" method="post">
                                                <input type="hidden" name="bookingId" value="@item.Bookingid" />
                                                <input type="hidden" name="serviceId" value="@item.Serviceid" />
                                                <input type="hidden" name="delta" value="1" />
                                                <button type="submit" class="btn btn-light">+</button>
                                            </form>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold">@rowSum.ToString("N2")</td>
                                    <td class="text-center">
                                        <form asp-action="RemoveService" method="post" 
                                              onsubmit="return confirm('Ви впевнені, що хочете видалити цю послугу з рахунку?');">
                                            <input type="hidden" name="bookingId" value="@item.Bookingid" />
                                            <input type="hidden" name="serviceId" value="@item.Serviceid" />
                                            <button type="submit" class="btn btn-link text-danger p-0" title="Видалити послугу">
                                                <i class="bi bi-trash3-fill fs-5"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="mt-3 text-start">
                <a asp-controller="Bookings" asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
                    Назад до списку
                </a>
            </div>
        </div>
    </div>
</div>