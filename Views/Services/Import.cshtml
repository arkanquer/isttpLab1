@{
    ViewData["Title"] = "Імпорт послуг з Excel";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 mx-auto" style="max-width: 600px;">
        <div class="card-body p-5">
            <h3 class="fw-bold text-center mb-4">Завантаження даних</h3>
            
            <div class="alert alert-info border-0 rounded-3 small mb-4">
                <i class="bi bi-info-circle me-2"></i>
                Будь ласка, оберіть файл у форматі <strong>.xlsx</strong>. 
                Система автоматично оновить існуючі послуги або додасть нові.
            </div>

            <form asp-action="Import" method="post" enctype="multipart/form-data">
                <div class="mb-4">
                    <label for="fileExcel" class="form-label fw-bold text-secondary small text-uppercase">
                        Excel-файл
                    </label>
                    <input type="file" name="fileExcel" id="fileExcel" 
                           class="form-control border-dark shadow-sm" accept=".xlsx" required />
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-dark btn-lg rounded-pill shadow-sm py-3 fw-bold">
                        <i class="bi bi-upload me-2"></i> Завантажити дані
                    </button>
                    <a asp-action="Index" class="btn btn-link text-muted text-decoration-none text-center small">
                        Скасувати та повернутися
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>