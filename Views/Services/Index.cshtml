@model IEnumerable<HotelBookingSystem.Models.Service>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark text-uppercase">Каталог послуг</h2>
        @if (User.IsInRole("admin"))
        {
            <a asp-action="Create" class="btn btn-success rounded-pill shadow-sm">
                <i class="bi bi-plus-circle"></i> Додати послугу
            </a>
        }
    </div>

    <div class="mb-4 text-end">
        <div class="btn-group shadow-sm rounded-2 overflow-hidden" role="group">
            <a asp-action="Index" asp-route-status="available"
               class="btn @(Context.Request.Query["status"] == "available" || string.IsNullOrEmpty(Context.Request.Query["status"]) ? "btn-dark" : "btn-outline-dark") px-3">
                Активні
            </a>
            <a asp-action="Index" asp-route-status="archived"
               class="btn @(Context.Request.Query["status"] == "archived" ? "btn-dark" : "btn-outline-dark") px-3">
                Архів
            </a>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            var photo = ((List<Medium>?)ViewBag.Photos)?.FirstOrDefault(m => m.Entityid == item.Serviceid);

            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden position-relative">
                    <div style="height: 220px; background-color: #f8f9fa;" class="position-relative">
                        @if (photo is not null)
                        {
                            <img src="@photo.Url" class="w-100 h-100" style="object-fit: cover;" alt="@item.Name">
                        }
                        else
                        {
                            <div class="d-flex h-100 align-items-center justify-content-center text-muted flex-column">
                                <i class="bi bi-stars" style="font-size: 3rem;"></i>
                                <span class="small">Немає фото</span>
                            </div>
                        }
                        <span class="position-absolute top-0 end-0 m-3 badge rounded-pill @(item.IsAvailable ? "bg-success" : "bg-warning text-dark")">
                            @(item.IsAvailable ? "Вільна" : "Недоступна")
                        </span>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title fw-bold mb-0">@item.Name</h5>
                            <span class="text-dark fw-bold">@(item.Price?.ToString("N2") ?? "0.00") грн</span>
                        </div>
                        
                        <p class="card-text text-muted small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @item.Description
                        </p>

                        @if (User.IsInRole("admin"))
                        {
                            <div class="mt-3 d-flex justify-content-between align-items-center">
                                <div class="btn-group flex-grow-1 me-2">
                                    <a asp-action="Edit" asp-route-id="@item.Serviceid"
                                       class="btn btn-outline-dark btn-sm d-flex align-items-center justify-content-center flex-grow-1">
                                        Редагувати
                                    </a>
                                    <form asp-action="UploadPhoto" method="post" enctype="multipart/form-data" class="d-contents">
                                        <input type="hidden" name="serviceId" value="@item.Serviceid" />
                                        <input type="file" name="photo" id="upload_@item.Serviceid" style="display:none;" onchange="this.form.submit()" />
                                        <button type="button" class="btn btn-outline-dark btn-sm px-3" onclick="document.getElementById('upload_@item.Serviceid').click()">
                                            <i class="bi bi-camera"></i>
                                        </button>
                                    </form>
                                </div>
                                <form asp-action="Delete" asp-route-id="@item.Serviceid" method="post" onsubmit="return confirm('Ви впевнені?')" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm px-3">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="mt-3">
                                @if (ViewBag.UserBookings is not null && ((IEnumerable<Booking>)ViewBag.UserBookings).Any())
                                {
                                    <form asp-controller="Bookings" asp-action="AddService" method="post">
                                        <input type="hidden" name="serviceId" value="@item.Serviceid" />
                                        <div class="mb-2">
                                            <select name="bookingId" class="form-select form-select-sm border-dark shadow-sm">
                                                @foreach (var b in (IEnumerable<Booking>)ViewBag.UserBookings)
                                                {
                                                    <option value="@b.Bookingid">
                                                        Ваше бронювання: (@b.Checkindate?.ToString("dd.MM") — @b.Checkoutdate?.ToString("dd.MM"))
                                                    </option>
                                                }
                                            </select>
                                        </div>
                                        <button type="submit" class="btn btn-primary w-100 rounded-pill @(!item.IsAvailable ? "disabled" : "")">Замовити</button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-100 rounded-pill disabled">Немає активних бронювань</button>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>