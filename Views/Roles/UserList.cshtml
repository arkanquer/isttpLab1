@model IEnumerable<HotelBookingSystem.Models.User>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark text-uppercase">Керування користувачами</h2>
    </div>

    <div class="card shadow-sm border-0 mb-4 p-3 bg-light">
        <form asp-action="UserList" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-bold small">Пошук за Email</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchEmail" value="@ViewData["CurrentEmailFilter"]" 
                           class="form-control border-start-0" placeholder="Введіть email для пошуку...">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small">Фільтр ролей</label>
                <select name="roleFilter" class="form-select border-dark">
                    <option value="">Всі користувачі</option>
                    <option value="admin" selected='@(ViewData["CurrentRoleFilter"]?.ToString() == "admin")'>Адміністратори</option>
                    <option value="user" selected='@(ViewData["CurrentRoleFilter"]?.ToString() == "user")'>Звичайні юзери</option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-dark w-100">
                    <i class="bi bi-funnel"></i> Застосувати
                </button>
                <a asp-action="UserList" class="btn btn-outline-secondary w-100">Скинути</a>
            </div>
        </form>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Email / Логін</th>
                        <th>Рік народження</th>
                        <th class="text-center" style="width: 250px;">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="bi bi-person-exclamation fs-1 d-block mb-2"></i>
                                Користувачів не знайдено
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <span class="fw-bold">@(user?.Email ?? "Без пошти")</span>
                                    @if (user?.Email == "admin@gmail.com")
                                    {
                                        <span class="badge bg-warning text-dark ms-2">Головний адмін</span>
                                    }
                                    @if (user?.UserName == User.Identity?.Name && User.Identity?.IsAuthenticated == true)
                                    {
                                        <span class="badge bg-info text-dark ms-2">Це ви</span>
                                    }
                                </td>
                                <td>@(user?.Year == 0 ? "—" : user?.Year)</td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-userid="@user?.Id">
                                            <i class="bi bi-shield-lock"></i> Права
                                        </a>
                                        
                                        @if (user?.Email != "admin@gmail.com" && user?.UserName != User.Identity?.Name)
                                        {
                                            <form asp-action="Delete" asp-route-id="@user?.Id" method="post" 
                                                  onsubmit="return confirm('Видалити користувача @user?.Email?');" 
                                                  class="d-inline ms-2">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Видалити
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>