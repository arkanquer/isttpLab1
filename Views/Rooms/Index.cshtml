@model IEnumerable<HotelBookingSystem.Models.Room>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Доступні номери</h2>
        <div>
            @if (User.IsInRole("admin"))
            {
                <a asp-action="Index" asp-route-status="active" class="btn btn-outline-primary">Активні</a>
                <a asp-action="Index" asp-route-status="archived" class="btn btn-outline-secondary">Архів</a>
                <a asp-action="Create" class="btn btn-success ms-2"><i class="bi bi-plus-circle"></i> Додати номер</a>
            }
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            var photo = ((List<Medium>?)ViewBag.Photos)?.FirstOrDefault(m => m.Entityid == item.Roomid);

            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden position-relative">
                    <div style="height: 220px; background-color: #e9ecef;" class="position-relative">
                        @if (photo is not null)
                        {
                            <img src="@photo.Url" class="w-100 h-100" style="object-fit: cover;" alt="Room Photo">
                        }
                        else
                        {
                            <div class="d-flex h-100 align-items-center justify-content-center text-muted flex-column">
                                <span>Немає фото</span>
                            </div>
                        }
                        
                        <span class="position-absolute top-0 end-0 m-3 badge rounded-pill @(item.Status == "available" ? "bg-success" : "bg-warning text-dark")">
                            @(item.Status?.ToLower() switch
                            {
                                "available" => "Вільний",
                                "maintenance" => "Обслуговування",
                                "occupied" => "Зайнятий",
                                "archived" => "Архів",
                                _ => item.Status
                            })
                        </span>
                    </div>

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title fw-bold mb-0">@item.Roomtype</h5>
                            <span class="text-primary fw-bold fs-5">@item.Pricepernight грн</span>
                        </div>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-door-closed"></i> Номер: @item.Roomnumber | 
                        </p>
                        
                        <div class="d-grid gap-2">
                            @if (User.IsInRole("admin"))
                            {
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Roomid" class="btn btn-outline-dark btn-sm">Редагувати</a>
                                    
                                    <form asp-action="UploadPhoto" method="post" enctype="multipart/form-data" class="d-inline">
                                        <input type="hidden" name="roomId" value="@item.Roomid" />
                                        <input type="file" name="photo" id="upload_@item.Roomid" style="display:none;" onchange="this.form.submit()" />
                                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="document.getElementById('upload_@item.Roomid').click()">
                                            <i class="bi bi-camera"></i>
                                        </button>
                                    </form>

                                    @if (photo is not null)
                                    {
                                        <form asp-action="DeletePhoto" method="post" class="d-inline">
                                            <input type="hidden" name="roomId" value="@item.Roomid" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Видалити фото?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                            else
                            {
                                <a asp-controller="Bookings" 
                                   asp-action="Create" 
                                   asp-route-roomId="@item.Roomid" 
                                   class="btn btn-primary btn-lg rounded-pill @(item.Status != "available" ? "disabled" : "")">
                                    Забронювати
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>