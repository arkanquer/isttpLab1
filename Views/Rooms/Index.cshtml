@model IEnumerable<HotelBookingSystem.Models.Room>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">База номерів</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm px-4">➕ Додати номер</a>
    </div>

    <div class="btn-group mb-4 shadow-sm" role="group">
        <a asp-action="Index" asp-route-status="active" 
           class="btn @(ViewData["CurrentStatus"]?.ToString() == "active" ? "btn-dark" : "btn-outline-dark") px-4">
            У базі
        </a>
        <a asp-action="Index" asp-route-status="archived" 
           class="btn @(ViewData["CurrentStatus"]?.ToString() == "archived" ? "btn-danger" : "btn-outline-danger") px-4">
            Архів
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 70px;" class="ps-3 text-muted">ID</th>
                        <th>№ Номера</th>
                        <th>Тип</th>
                        <th>Ціна / ніч</th>
                        <th>Поточний статус</th>
                        <th class="text-center" style="width: 150px;">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-door-closed fs-2 d-block mb-2"></i>
                                Список порожній.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 text-muted fw-bold">@item.Roomid</td>
                            <td class="fw-bold fs-5 text-dark">@item.Roomnumber</td>
                            <td>@item.Roomtype</td>
                            <td class="fw-bold">@item.Pricepernight?.ToString("N2") грн</td>
                            <td>
                                @{ var s = item.Status?.Trim().ToLower(); }
                                @if (s == "available" || s == "вільно") { <span class="badge bg-success">Вільно</span> }
                                else if (s == "maintenance" || s == "ремонт") { <span class="badge bg-danger">Ремонт</span> }
                                else if (s == "occupied" || s == "зайнята") { <span class="badge bg-warning text-dark">Зайнята</span> }
                                else if (s == "archived") { <span class="badge bg-secondary">В архіві</span> }
                                else { <span class="badge bg-info text-dark">@item.Status</span> }
                            </td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Roomid" class="btn btn-sm btn-outline-primary" title="Редагувати">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (item.Status?.ToLower() == "archived") {
                                        <form asp-action="Restore" asp-route-id="@item.Roomid" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Відновити"><i class="bi bi-arrow-up-circle"></i></button>
                                        </form>
                                    } else {
                                        <form asp-action="Archive" asp-route-id="@item.Roomid" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="В архів"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>